---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });

const readingTime = (body: string | undefined) =>
  Math.max(1, Math.round((body ?? '').split(/\s+/).length / 200));
---

<Layout title="Blog · Tanmaya Lodhia" description="Writing on markets, research process, and quantitative finance by Tanmaya Lodhia.">
  <div class="mx-auto max-w-3xl px-6 py-16">
    <p class="text-sm font-medium uppercase tracking-[0.25em] text-accent">Notes &amp; essays</p>
    <h1 class="mt-3 font-serif text-5xl font-semibold text-ink">Blog</h1>
    <p class="mt-4 max-w-xl leading-relaxed text-ink-soft">
      Occasional writing on markets, research process, and things I've learned building
      projects. Written the way the papers are: claims first, hedges attached.
    </p>

    <div class="mt-14 space-y-2">
      {posts.map((post, i) => (
        <a
          href={`/blog/${post.id}`}
          class="group relative block border-t border-line py-9 transition last:border-b hover:bg-card/60"
        >
          <div class="flex items-baseline gap-6">
            <span class="hidden font-serif text-2xl italic text-ink-faint transition group-hover:text-accent sm:block">
              {String(posts.length - i).padStart(2, '0')}
            </span>
            <div class="min-w-0 flex-1">
              <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-xs font-medium uppercase tracking-widest text-ink-faint">
                <span>{fmt(post.data.date)}</span>
                <span class="text-accent">&middot;</span>
                <span>{readingTime(post.body)} min read</span>
              </div>
              <h2 class="mt-3 font-serif text-3xl font-semibold leading-snug text-ink transition group-hover:text-accent-soft">
                {post.data.title}
              </h2>
              <p class="mt-3 max-w-xl leading-relaxed text-ink-soft">{post.data.description}</p>
              {post.data.tags.length > 0 && (
                <div class="mt-4 flex flex-wrap gap-2">
                  {post.data.tags.map((tag) => (
                    <span class="rounded-full border border-line px-2.5 py-0.5 text-xs text-ink-faint">{tag}</span>
                  ))}
                </div>
              )}
            </div>
            <span class="hidden self-center text-2xl text-ink-faint transition group-hover:translate-x-1 group-hover:text-accent sm:block">
              &rarr;
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>
