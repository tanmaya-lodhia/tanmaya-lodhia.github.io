---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { categoryOrder, categoryMeta } from '../../data/blogCategories';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);

const readingTime = (body: string | undefined) =>
  Math.max(1, Math.round((body ?? '').split(/\s+/).length / 200));

const sections = categoryOrder
  .map((key) => ({
    key,
    meta: categoryMeta[key],
    posts: allPosts.filter((p) => p.data.category === key),
  }))
  .filter((s) => s.posts.length > 0);
---

<Layout title="Blog · Tanmaya Lodhia" description="Writing on markets, research process, and quantitative finance by Tanmaya Lodhia.">
  <div class="mx-auto max-w-3xl px-6 py-16">
    <p class="text-sm font-medium uppercase tracking-[0.25em] text-accent">Notes &amp; essays</p>
    <h1 class="mt-3 font-serif text-5xl font-semibold text-ink">Blog</h1>
    <p class="mt-4 max-w-xl leading-relaxed text-ink-soft">
      Research diary, paper notes, essays, explainers, and short current thoughts. Written the
      way the papers are: claims first, hedges attached.
    </p>

    {sections.length === 0 && (
      <p class="mt-14 text-ink-faint">Nothing published yet. Check back soon.</p>
    )}

    <nav class="mt-12 flex flex-wrap gap-2">
      {sections.map((s) => (
        <a href={`#${s.key}`} class="rounded-full border border-line px-3 py-1 text-xs font-medium text-ink-soft transition hover:border-accent hover:text-accent">
          {s.meta.label}
        </a>
      ))}
    </nav>

    {sections.map((s, i) => (
      <section id={s.key} class="mt-20 scroll-mt-24">
        <div class="flex items-baseline gap-5">
          <span class="font-serif text-5xl font-semibold text-line select-none" aria-hidden="true">
            {String(i + 1).padStart(2, '0')}
          </span>
          <div>
            <h2 class="font-serif text-3xl font-semibold text-ink">{s.meta.label}</h2>
            <p class="mt-1 font-serif text-base italic text-accent-soft">{s.meta.subtitle}</p>
          </div>
        </div>
        <div class="mt-5 h-px w-full bg-gradient-to-r from-accent/60 via-line to-transparent"></div>

        <div class="mt-8 overflow-hidden rounded-xl border border-line bg-card-deep">
          {s.posts.map((post) => (
            <a
              href={`/blog/${post.id}`}
              class="group relative block border-b border-line px-7 py-7 transition last:border-b-0 hover:bg-card"
            >
              <div class="flex items-baseline gap-6">
                <div class="min-w-0 flex-1">
                  <h3 class="font-serif text-2xl font-semibold leading-snug text-ink transition group-hover:text-accent-soft">
                    {post.data.title}
                  </h3>
                  <p class="mt-2 max-w-xl leading-relaxed text-ink-soft">{post.data.description}</p>
                  <div class="mt-3 flex flex-wrap items-center gap-x-3 gap-y-1 text-xs font-medium uppercase tracking-widest text-ink-faint">
                    <span>{readingTime(post.body)} min read</span>
                    {post.data.tags.map((tag) => (
                      <>
                        <span class="text-accent">&middot;</span>
                        <span>{tag}</span>
                      </>
                    ))}
                  </div>
                </div>
                <span class="hidden self-center text-2xl text-ink-faint transition group-hover:translate-x-1 group-hover:text-accent sm:block">
                  &rarr;
                </span>
              </div>
            </a>
          ))}
        </div>
      </section>
    ))}
  </div>
</Layout>
